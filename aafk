local virtualInput = game:GetService("VirtualInputManager")

local isLooping = false
local loopCoroutine = nil

local function pressRightBracket()
    virtualInput:SendKeyEvent(true, Enum.KeyCode.RightBracket, false, game)
    virtualInput:SendKeyEvent(false, Enum.KeyCode.RightBracket, false, game)
end

local function toggleLoop()
    if isLooping then
        -- Stop the loop
        isLooping = false
    else
        -- Start the loop
        isLooping = true
        loopCoroutine = coroutine.create(function()
            while isLooping do
                pressRightBracket()
                task.wait(1) -- adjust delay as needed
            end
        end)
        coroutine.resume(loopCoroutine)
    end
end
toggleLoop()
