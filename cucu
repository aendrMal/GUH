local TweenService = game:GetService("TweenService")
local player = game.Players.LocalPlayer
local character = player.Character or player.CharacterAdded:Wait()
local hrp = character:WaitForChild("HumanoidRootPart")
local displayName = ""
local virtualInput = game:GetService("VirtualInputManager")

local plo
if character and character:FindFirstChildOfClass("Humanoid") then
    displayName = character:FindFirstChildOfClass("Humanoid").DisplayName
end

for i, v in ipairs(workspace.Plots:GetDescendants()) do
    if v.Name == "Username" and v.Text == displayName then
        plo = v.Parent.Parent.Parent.Parent
        break
    end
end

if plo then
    print("Found Plot:", plo)
    local gemDig = plo.Model.Plots:FindFirstChild("GemDig")
else
    print("PLO not found!")
end

local ignoreNames = {
    ["Farmer Statue"] = true,
    ["Snail"] = true,
    ["Snail Nest"] = true,
    ["Wooden Trellis"] = true,
    ["Horse"] = true,
    ["Horse Nest"] = true,
    ["Turtle"] =  true,
    ["Turtle Nest"] = true,
    ["Panda"] = true,
    ["Panda Nest"] = true,
    ["Red Panda"] = true,
    ["Red Panda Nest"] = true,
    ["GemDig"] = true,
    ["Common Egg"] = true,
    ["Uncommon Egg"] = true,
    ["Rare Egg"] = true,
    ["Legendary Egg"] = true,
    ["Mythic Egg"] = true,
}

if getgenv().tweenLoopRunning == nil then
    getgenv().tweenLoopRunning = false
end

local function tweenAndPressE()
    local startPosition = hrp.CFrame
    local gemDigModel = plo.Model.Plots:FindFirstChild("GemDig")
    
    if not gemDigModel or not gemDigModel.PrimaryPart then
        return
    end
    
    local targetCFrame = gemDigModel.PrimaryPart.CFrame
    local tweenInfo = TweenInfo.new(1, Enum.EasingStyle.Linear, Enum.EasingDirection.Out)
    local tweenToGem = TweenService:Create(hrp, tweenInfo, {CFrame = targetCFrame})
    tweenToGem:Play()
    while tweenToGem.PlaybackState ~= Enum.PlaybackState.Completed do
        wait()
    end

    virtualInput:SendKeyEvent(true, Enum.KeyCode.E, false, game)
    wait(0.5)
    virtualInput:SendKeyEvent(false, Enum.KeyCode.E, false, game)

    local tweenBack = TweenService:Create(hrp, tweenInfo, {CFrame = startPosition})
    tweenBack:Play()
    while tweenBack.PlaybackState ~= Enum.PlaybackState.Completed do
        wait()
    end
end

if plo then
    getgenv().tweenLoopRunning = true
    coroutine.wrap(function()
        while getgenv().tweenLoopRunning do
            tweenAndPressE()
            wait(1)
        end
    end)()
end

if plo then
    for _, model in ipairs(plo.Model.Plots:GetChildren()) do
        if model:IsA("Model") and not ignoreNames[model.Name] then
            local success = pcall(function()
                if model.PrimaryPart then
                    model:SetPrimaryPartCFrame(hrp.CFrame * CFrame.new(0, -2, 0))
                else
                    for _, part in ipairs(model:GetDescendants()) do
                        if part:IsA("BasePart") then
                            part.CFrame = hrp.CFrame * CFrame.new(0, -2, 0)
                        end
                    end
                end
            end)
            if success then
                for _, part in ipairs(model:GetDescendants()) do
                    if part:IsA("BasePart") then
                        pcall(function()
                            part.Size = Vector3.new(1, 1, 1)
                            part.CanCollide = false
                        end)
                    end
                end
            end
        end
    end
end

