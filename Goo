local TweenService = game:GetService("TweenService")
local UserInputService = game:GetService("UserInputService")
local player = game.Players.LocalPlayer
local character = nil
local hrp = nil

-- Function to wait for character and HumanoidRootPart
local function waitForCharacter()
    repeat
        character = player.Character or player.CharacterAdded:Wait()
        hrp = character:FindFirstChild("HumanoidRootPart")
        task.wait(0.5)
    until hrp
end

-- Initial wait for character spawn
waitForCharacter()

-- Monitor if character falls into the void
task.spawn(function()
    while true do
        if hrp and hrp.Position.Y < -50 then -- threshold for falling into the void
            print("Character fell into the void, waiting for respawn...")
            waitForCharacter()
        end
        task.wait(1)
    end
end)

local displayName = ""
if character and character:FindFirstChildOfClass("Humanoid") then
    displayName = character:FindFirstChildOfClass("Humanoid").DisplayName
end

-- Find the plot object
