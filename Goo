-- Initialize toggle variable
if getgenv().tweenLoopRunning == nil then
    getgenv().tweenLoopRunning = false
end

local function tweenAndPressE()
    -- Wait for HRP to be valid
    if not hrp then return end
    local startPosition = hrp.CFrame
    local gemDigModel = (plo and plo:FindFirstChild("Model") and plo.Model:FindFirstChild("GemDig"))
    if not gemDigModel or not gemDigModel.PrimaryPart then
        return
    end

    local targetPosition = gemDigModel.PrimaryPart.CFrame.Position

    -- Tween position instead of CFrame
    local tweenInfo = TweenInfo.new(1, Enum.EasingStyle.Linear, Enum.EasingDirection.Out)
    local tweenToGem = TweenService:Create(hrp, tweenInfo, {Position = targetPosition})
    tweenToGem:Play()

    -- Wait for tween to complete with timeout
    local tweenTimeout = 2 -- seconds
    local elapsed = 0
    while tweenToGem.PlaybackState ~= Enum.PlaybackState.Completed and elapsed < tweenTimeout do
        task.wait(0.1)
        elapsed = elapsed + 0.1
    end

    -- Send "E" key press
    virtualInput:SendKeyEvent(true, Enum.KeyCode.E, false, game)
    task.wait(0.2)
    virtualInput:SendKeyEvent(false, Enum.KeyCode.E, false, game)

    -- Tween back to original position
    local tweenBack = TweenService:Create(hrp, tweenInfo, {Position = startPosition.Position})
    tweenBack:Play()

    -- Wait for the second tween to complete with timeout
    local elapsedBack = 0
    while tweenBack.PlaybackState ~= Enum.PlaybackState.Completed and elapsedBack < tweenTimeout do
        task.wait(0.1)
        elapsedBack = elapsedBack + 0.1
    end
end

-- Toggle loop with R key
UserInputService.InputBegan:Connect(function(input, gameProcessed)
    if gameProcessed then return end
    if input.KeyCode == Enum.KeyCode.R then
        getgenv().tweenLoopRunning = not getgenv().tweenLoopRunning
        if getgenv().tweenLoopRunning then
            print("Tween Loop Started")
        else
            print("Tween Loop Stopped")
        end
    end
end)

-- Main loop
task.spawn(function()
    while true do
        if getgenv().tweenLoopRunning then
            -- Check if character is valid before running
            if hrp then
                tweenAndPressE()

                task.wait(1)

                if plo and plo:FindFirstChild("Model") and plo.Model:FindFirstChild("Plots") then
                    for _, model in ipairs(plo.Model.Plots:GetChildren()) do
                        if model:IsA("Model") and not ignoreNames[model.Name] then
                            -- Safely set position
                            local success, err = pcall(function()
                                if model.PrimaryPart then
                                    model:SetPrimaryPartCFrame(hrp.CFrame * CFrame.new(0, -2, 0))
                                else
                                    for _, part in ipairs(model:GetDescendants()) do
                                        if part:IsA("BasePart") then
                                            part.CFrame = hrp.CFrame * CFrame.new(0, -2, 0)
                                            part.CanCollide = false
                                        end
                                    end
                                end
                            end)
                            if success then
                                -- Optional: resize parts
                                for _, part in ipairs(model:GetDescendants()) do
                                    if part:IsA("BasePart") then
                                        pcall(function()
                                            part.Size = Vector3.new(1, 1, 1)
                                            part.CanCollide = false
                                        end)
                                    end
                                end
                            end
                            -- Handle "Sell_Crops" button
                            for _, m in ipairs(plo.Model.Sell_Main:GetChildren()) do
                                if m.Name == "Sell_Crops" then
                                    pcall(function()
                                        if m:IsA("BasePart") then
                                            m.CFrame = hrp.CFrame * CFrame.new(0, -2, 0)
                                            m.CanCollide = false
                                        end
                                    end)
                                end
                            end
                        end
                    end
                end
                task.wait(2)
            else
                -- HRP no longer valid, wait and retry
                waitForCharacter()
            end
        else
            task.wait(0.5)
        end
    end
end)()

-- Optional: send "R" key at start
virtualInput:SendKeyEvent(true, Enum.KeyCode.R, false, game)
virtualInput:SendKeyEvent(false, Enum.KeyCode.R, false, game)
