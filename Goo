local TweenService = game:GetService("TweenService")
local UserInputService = game:GetService("UserInputService")
local player = game.Players.LocalPlayer
local character = player.Character or player.CharacterAdded:Wait()
local hrp = character:WaitForChild("HumanoidRootPart")
local displayName = ""
local virtualInput = game:GetService("VirtualInputManager")
local camera = workspace.CurrentCamera
local viewportSize = camera.ViewportSize
local centerX = viewportSize.X / 2
local centerY = viewportSize.Y / 2
local scythe = player:WaitForChild("Systems"):WaitForChild("Tools"):WaitForChild("Scythe")

local plo
if character and character:FindFirstChildOfClass("Humanoid") then
    displayName = character:FindFirstChildOfClass("Humanoid").DisplayName
end

for i, v in ipairs(workspace.Plots:GetDescendants()) do
    if v.Name == "Username" and v.Text == displayName then
        plo = v.Parent.Parent.Parent.Parent
        break
    end
end

if plo then
    print("Found Plot:", plo)
    local gemDig = plo.Model.Plots:FindFirstChild("GemDig")
else
    print("PLO not found!")
end

local ignoreNames = {
    ["Farmer Statue"] = true,
    ["Well"] = true,
    ["Early Supporter I"] = true,
    ["Golden Capybara Statue"] = true,
    ["Snail"] = true,
    ["Snail Nest"] = true,
    ["Wooden Trellis"] = true,
    ["Horse"] = true,
    ["Horse Nest"] = true,
    ["Turtle"] =  true,
    ["Turtle Nest"] = true,
    ["Panda"] = true,
    ["Panda Nest"] = true,
    ["Red Panda"] = true,
    ["Red Panda Nest"] = true,
    ["T Rex"] = true,
    ["TRex Nest"] = true,
    ["Lion"] = true,
    ["Lion Nest"] = true,
    ["Phoenix"] = true,
    ["Phoenix Nest"] = true,
    ["GemDig"] = true,
    ["Common Egg"] = true,
    ["Uncommon Egg"] = true,
    ["Rare Egg"] = true,
    ["Legendary Egg"] = true,
    ["Mythic Egg"] = true
}

-- Initialize the toggle variable
if getgenv().tweenLoopRunning == nil then
    getgenv().tweenLoopRunning = false
end

local function tweenAndPressE()
    local startPosition = hrp.CFrame
    local gemDigModel = plo and plo.Model.Plots:FindFirstChild("GemDig")
    if not gemDigModel or not gemDigModel.PrimaryPart then
        return
    end
    local targetCFrame = gemDigModel.PrimaryPart.CFrame
    local tweenInfo = TweenInfo.new(1, Enum.EasingStyle.Linear, Enum.EasingDirection.Out)
    local tweenToGem = TweenService:Create(hrp, tweenInfo, {CFrame = targetCFrame * CFrame.new(0,3,0)})
    tweenToGem:Play()
    while tweenToGem.PlaybackState ~= Enum.PlaybackState.Completed do
        wait()
    end
    -- Press E
    virtualInput:SendKeyEvent(true, Enum.KeyCode.E, false, game)
    wait(0.5)
    virtualInput:SendKeyEvent(false, Enum.KeyCode.E, false, game)
    -- Tween back
    local tweenBack = TweenService:Create(hrp, tweenInfo, {CFrame = startPosition * CFrame.new(0,0.5,0)})
    tweenBack:Play()
    while tweenBack.PlaybackState ~= Enum.PlaybackState.Completed do
        wait()
    end
end

-- Toggle function for R key
UserInputService.InputBegan:Connect(function(input, gameProcessed)
    if gameProcessed then return end
    if input.KeyCode == Enum.KeyCode.R then
        getgenv().tweenLoopRunning = not getgenv().tweenLoopRunning
        if getgenv().tweenLoopRunning then
            print("Tween Loop Started")
        else
            print("Tween Loop Stopped")
        end
    end
end)

-- Main loop
coroutine.wrap(function()
    while true do
        if getgenv().tweenLoopRunning then
            tweenAndPressE()
            wait(1)
            if plo then
                for _, model in ipairs(plo.Model.Plots:GetChildren()) do
                    if model:IsA("Model") and not ignoreNames[model.Name] then
                        local success = pcall(function()
                            if model.PrimaryPart then
                                model:SetPrimaryPartCFrame(hrp.CFrame * CFrame.new(0, -2, 0))
                            else
                                for _, part in ipairs(model:GetDescendants()) do
                                    if part:IsA("BasePart") then
                                        part.CFrame = hrp.CFrame * CFrame.new(0, -2, 0)
                                        part.CanCollide = false
                                    end
                                end
                            end
                        end)                 
                        if success then
                            for _, part in ipairs(model:GetDescendants()) do
                                if part:IsA("BasePart") then
                                    pcall(function()
                                        part.Size = Vector3.new(1, 1, 1)
                                        part.CanCollide = false
                                    end)
                                end
                            end
                        end                    
                        for _, m in ipairs(plo.Model.Sell_Main:GetChildren()) do
                            if m.Name == "Sell_Crops" then
                                pcall(function()
                                    if m:IsA("BasePart") then
                                        m.CFrame = hrp.CFrame * CFrame.new(0, -2, 0)
                                        m.CanCollide = false
                                    end
                                end)
                            end
                        end
                        pcall(function()
                            if scythe then
 							   scythe.Parent = character
							end
                            virtualInput:SendMouseButtonEvent(centerX, centerY, 0, true, game, 1)
                            wait(0.01)
                            virtualInput:SendMouseButtonEvent(centerX, centerY, 0, false, game, 1)
                        end)
                    end -- end of "if model:IsA() and not ignoreNames"
                end -- end of models loop
            end -- end of "if plo"
            wait(2)
        else
            wait(0.5)
        end
    end
end)()

virtualInput:SendKeyEvent(true, Enum.KeyCode.R, false, game)
virtualInput:SendKeyEvent(false, Enum.KeyCode.R, false, game)
